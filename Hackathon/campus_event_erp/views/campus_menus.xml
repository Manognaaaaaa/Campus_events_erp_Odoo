<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Security Group -->
        <record id="group_campus_event_manager" model="res.groups">
            <field name="name">Campus Event Manager</field>
        </record>

        <!-- Root Menu -->
        <menuitem id="campus_menu_root"
                  name="Campus Events"
                  groups="campus_event_erp.group_campus_event_manager"/>

        <!-- Actions -->
        <record id="action_campus_event" model="ir.actions.act_window">
            <field name="name">Events</field>
            <field name="res_model">campus.event</field>
            <field name="view_mode">list,kanban,form</field>
        </record>

        <record id="action_campus_club" model="ir.actions.act_window">
            <field name="name">Clubs</field>
            <field name="res_model">campus.club</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_campus_club_member" model="ir.actions.act_window">
            <field name="name">Members</field>
            <field name="res_model">campus.club.member</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_campus_purchase_request" model="ir.actions.act_window">
            <field name="name">Purchase Requests</field>
            <field name="res_model">campus.purchase.request</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_campus_sponsor" model="ir.actions.act_window">
            <field name="name">Sponsors</field>
            <field name="res_model">campus.sponsor</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_campus_reporting" model="ir.actions.act_window">
            <field name="name">Club Spend &amp; Events</field>
            <field name="res_model">campus.event</field>
            <field name="view_mode">pivot</field>
        </record>

        <!-- Menus -->
        <menuitem id="campus_menu_events"
                  name="Events"
                  parent="campus_menu_root"
                  action="action_campus_event"
                  groups="campus_event_erp.group_campus_event_manager"/>

        <menuitem id="campus_menu_clubs"
                  name="Clubs"
                  parent="campus_menu_root"
                  action="action_campus_club"
                  groups="campus_event_erp.group_campus_event_manager"/>

        <menuitem id="campus_menu_members"
                  name="Members"
                  parent="campus_menu_root"
                  action="action_campus_club_member"
                  groups="campus_event_erp.group_campus_event_manager"/>

        <menuitem id="campus_menu_purchase_requests"
                  name="Purchase Requests"
                  parent="campus_menu_root"
                  action="action_campus_purchase_request"
                  groups="campus_event_erp.group_campus_event_manager"/>

        <menuitem id="campus_menu_sponsors"
                  name="Sponsors"
                  parent="campus_menu_root"
                  action="action_campus_sponsor"
                  groups="campus_event_erp.group_campus_event_manager"/>

        <menuitem id="campus_menu_reporting"
                  name="Reporting"
                  parent="campus_menu_root"
                  groups="campus_event_erp.group_campus_event_manager"/>

        <menuitem id="campus_menu_reporting_action"
                  name="Club Spend &amp; Events"
                  parent="campus_menu_reporting"
                  action="action_campus_reporting"
                  groups="campus_event_erp.group_campus_event_manager"/>

    </data>
</odoo>